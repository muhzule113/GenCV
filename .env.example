# ============================================================
# GenCV Environment Configuration
# ============================================================
# Priority: .env.{NODE_ENV} > .env
#   - development: .env.development (default)
#   - production:  .env.production
# ============================================================

PORT=5000
NODE_ENV=development

# Database (PostgreSQL self-hosted via Docker)
# Format: postgres://gencv_user:<password>@127.0.0.1:5432/gencv
DATABASE_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# DeepSeek
DEEPSEEK_API_KEY=

# CORS — comma-separated for multiple origins
#   Dev: http://localhost:5173
#   Prod: https://your-domain.com,https://admin.your-domain.com
CLIENT_URL=http://localhost:5173

# Midtrans (sandbox by default)
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CLIENT_KEY=
VITE_MIDTRANS_CLIENT_KEY=

# Frontend (Vite) — forwarded to browser
VITE_API_BASE_URL=http://localhost:5000
