# ============================================================
# GenCV Environment Configuration
# ============================================================
# Priority: .env.{NODE_ENV} > .env
# Copy to .env and fill values.
# ============================================================

PORT=5000
NODE_ENV=development

# Docker Compose Postgres password (used by docker-compose.yml)
DB_PASSWORD=gencv_dev_password

# Database (PostgreSQL self-hosted)
# Local:  postgres://gencv_user:gencv_dev_password@127.0.0.1:5432/gencv
# Docker: postgres://gencv_user:${DB_PASSWORD}@postgres:5432/gencv
DATABASE_URL=postgres://gencv_user:gencv_dev_password@127.0.0.1:5432/gencv

# Better Auth (required) — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Google OAuth (required for "Login with Google")
# Redirect URI (dev):  http://localhost:5000/api/auth/callback/google
# Redirect URI (prod): https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# DeepSeek (AI summary / letter / job match)
DEEPSEEK_API_KEY=

# CORS — comma-separated frontend origins
CLIENT_URL=http://localhost:5173

# Midtrans (token top-up) — optional until payments are needed
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CLIENT_KEY=
VITE_MIDTRANS_CLIENT_KEY=

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:5000
VITE_APP_URL=http://localhost:5173

# SMTP (Sumopod / Gmail / dll) — wajib untuk kirim kode ke inbox
SMTP_HOST=smtp.sumopod.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# WAJIB: alamat email valid yang diizinkan provider (bukan username SMTP)
# Contoh Sumopod: email yang terdaftar / custom domain di dashboard
SMTP_FROM=GenCV <noreply@domainkamu.com>

# Optional observability
SENTRY_DSN=
VITE_SENTRY_DSN=
